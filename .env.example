# ---------------------------------------------------------------------------
# PrepPilot — environment configuration
# Copy to `.env.local` and fill in what you have. Everything is OPTIONAL:
# without keys the app runs in a fully-functional offline demo mode.
# ---------------------------------------------------------------------------

# Anthropic — enables true LLM-driven autonomous tool use (recommended).
# Without it, the agent runs a deterministic heuristic planner that still calls
# all three data sources and produces a full summary.
ANTHROPIC_API_KEY=
# Optional: override the model (defaults to claude-3-5-sonnet-latest)
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Tavily — enables live web search (https://tavily.com).
# Without it, the search tool uses a curated payer knowledge base.
TAVILY_API_KEY=

# Optional: where the MCP server stores its SQLite memory DB.
# Defaults to ./.data/office-memory.db
# MEMORY_DB_PATH=
